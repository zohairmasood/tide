# --- Data feed -------------------------------------------------------------
# mock = no key needed; polygon = live, broad screened universe
DATA_PROVIDER=mock
POLYGON_API_KEY=

# --- Claude analyst notes --------------------------------------------------
# Leave blank to disable analyst notes (the UI hides the section gracefully).
ANTHROPIC_API_KEY=
ANALYST_MODEL=claude-opus-4-8

# --- Model artifact --------------------------------------------------------
MODEL_PATH=./.model/model.joblib

# --- Refresh cadence / ranking ---------------------------------------------
REFRESH_SECONDS=3          # cheap re-rank of the candidate pool
SCREEN_SECONDS=900         # expensive full-universe scan (15 min)
TOP_N=5                    # live leaderboard size
CANDIDATE_POOL=50          # names kept by the broad scan for cheap re-ranking
SAFE_THRESHOLD=0.55        # P(safe) gate for ranking eligibility

# --- Screening thresholds (broad universe) ---------------------------------
SCREEN_MIN_PRICE=3.0
SCREEN_MAX_PRICE=2000.0
SCREEN_MIN_DOLLAR_VOLUME=5000000

# --- Calibration-quality gate (controls whether probabilities are shown) ----
MAX_CALIB_BRIER=0.15
MIN_CALIB_N=500

# --- Paper execution (SIMULATED — no external brokerage needed) -------------
PAPER_CASH=100000          # starting simulated cash
PAPER_NOTIONAL=10000       # $ per armed trade
PAPER_SLIPPAGE_BPS=5       # modeled slippage on fills
STOP_PCT=0.05              # default stop (target comes from POP_TARGET_PCT = +10%)

# --- Smart-money alt-data (optional; needs ONE of these keys) ---------------
# Congressional trade disclosures. No brokerage/citizenship requirement.
QUIVER_API_KEY=            # https://api.quiverquant.com (Hobbyist ~$30/mo)
FINNHUB_API_KEY=           # https://finnhub.io (congressional endpoint, cheaper)
